# ============================================================
# File Manager 环境变量配置
# ------------------------------------------------------------
# 使用方式：cp .env.example .env，然后按需修改
# 注意：.env 含敏感信息，切勿提交到仓库（已在 .gitignore 中忽略）
# ============================================================

# ---- Docker 镜像 ----
# CI 构建并推送到 Docker Hub 的镜像地址，按需改成你的仓库
IMAGE=wzpa/file-manager:2.0.2

# 对外暴露端口（容器内固定 8080）
PORT=23456

# ---- PostgreSQL 配置 ----
# 使用 docker-compose.yaml（自带数据库）时：
#   POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB 用于初始化内置 PostgreSQL
# 使用 docker-compose.external-db.yaml（外部数据库）时：
#   POSTGRES_HOST / POSTGRES_PORT 指向你已有的 PostgreSQL
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=fsv2
POSTGRES_USER=filemanager
POSTGRES_PASSWORD=changeme

# ---- Redis 配置 ----
# 使用 docker-compose.yaml（自带数据库）时：HOST/PORT 会被忽略，自动连接内置 Redis
# 使用 docker-compose.external-db.yaml 时：HOST/PORT 指向你已有的 Redis
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# ---- 应用密钥 ----
# JWT 签名密钥。请务必改为一个随机的长字符串（不少于 6 位的大小写字母+数字+符号）！
# 注意：不要使用 "RANDOM"--容器每次重启都会重新生成，导致所有已登录用户掉线。
HMAC_KEY=change-this-to-a-random-secret
